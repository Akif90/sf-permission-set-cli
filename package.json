{
  "name": "permcraft",
  "version": "0.1.0",
  "description": "Interactive CLI to manage Salesforce permission set XML files",
  "type": "module",
  "bin": {
    "permcraft": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts",
    "format": "prettier --write 'src/**/*.ts'"
  },
  "keywords": ["salesforce", "permission-set", "sfdx", "cli"],
  "license": "MIT",
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "dependencies": {
    "fast-xml-parser": "^4.3.0",
    "fuse.js": "^7.0.0",
    "inquirer": "^9.2.0"
  }
}
