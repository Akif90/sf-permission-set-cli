{
  "name": "permcraft",
  "version": "0.2.0",
  "description": "Interactive CLI to manage Salesforce permission set XML files",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "permcraft": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts",
    "format": "prettier --write 'src/**/*.ts'",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "salesforce",
    "permission-set",
    "sfdx",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Akif90/sf-permission-set-cli.git"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/inquirer-autocomplete-prompt": "^3.0.3",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "dependencies": {
    "fast-xml-parser": "^4.3.0",
    "fuse.js": "^7.0.0",
    "inquirer": "^9.2.0",
    "inquirer-autocomplete-prompt": "^3.0.1"
  }
}
